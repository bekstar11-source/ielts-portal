rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'bekstar11@gmail.com'
      );
    }

    function isTeacher() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // Helper function to check if user is authenticated
    function isAuth() {
        return request.auth != null;
    }

    // USERS
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && (request.auth.uid == userId || isAdmin());

      // O'ziga tegishli subcollection'larga (vocabulary, mistakes, wordbank) ruxsat
      match /vocabulary/{wordId} {
        allow read, write: if isAuth() && (request.auth.uid == userId || isAdmin());
      }
      match /wordbank/{wordId} {
        allow read, write: if isAuth() && (request.auth.uid == userId || isAdmin());
      }
      match /mistakes/{mistakeId} {
        allow read, write: if isAuth() && (request.auth.uid == userId || isAdmin());
      }
      match /mistakeSessions/{sessionId} {
        allow read, write: if isAuth() && (request.auth.uid == userId || isAdmin());
      }
      // Sinonim/antonim juftlari: nested subcollection
      match /synonymPairs/{testId}/pairs/{pairId} {
        allow read, write: if isAuth() && (request.auth.uid == userId || isAdmin());
      }
    }

    // TESTS (O'qish hammaga, Yozish faqat adminga)
    match /tests/{testId} {
      allow read: if true;
      allow create: if isAdmin() || isTeacher();
      allow update, delete: if isAdmin() || (isTeacher() && resource.data.createdBy == request.auth.uid);
    }

    // ANNOUNCEMENTS (Yangiliklar)
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // RESULTS (Natijalar)
    match /results/{resultId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin() || isTeacher());
      allow create: if isAuth(); 
      allow update: if isAdmin() || isTeacher();
      allow delete: if isAdmin();
    }
    
    // GROUPS
    match /groups/{groupId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isTeacher();
    }
    
    // TEST SETS
    match /testSets/{setId} {
        allow read: if isAuth();
        allow write: if isAdmin();
    }

    // LOGS
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if true; // anyone can log (login, register, etc.)
      allow update, delete: if isAdmin();
    }
    
    // ACCESS KEYS
    match /accessKeys/{keyId} {
      allow read: if true; // Kalitni tekshirish uchun
      allow write: if isAdmin() || (isAuth() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedBy', 'usedByName', 'usedAt']));
    }

    // PODCASTS (O'qish autentifikatsiya bo'lganlarga, Yozish faqat adminga)
    match /podcasts/{podcastId} {
      allow read: if isAuth();
      allow write: if isAdmin();

      match /segments/{segmentId} {
        allow read: if isAuth();
        allow write: if isAdmin();
      }
      match /mcqQuestions/{questionId} {
        allow read: if isAuth();
        allow write: if isAdmin();
      }
      match /gapFill/{docId} {
        allow read: if isAuth();
        allow write: if isAdmin();
      }
      match /vocabulary/{wordId} {
        allow read: if isAuth();
        allow write: if isAdmin();
      }
    }

    // PODCAST ATTEMPTS (O'quvchi o'z urinishini boshqaradi)
    match /podcastAttempts/{attemptId} {
      allow read: if isAuth() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
